    xt -- "[B, TC, 1]" --> DEC2
    kv -. "read" .-> DEC2
    DEC2 -- "[B, TC, V]" --> dlog
    dlog -- "[B, TC, V]" --> DL
    x0 -- "labels [B, TC]" --> DL
    elog -- "[B, FS, V]" --> EL

