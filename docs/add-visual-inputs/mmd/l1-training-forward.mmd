%% L1 — SFTDiffusion training forward (sft_model.py:276-431)
%% P=prompt_len, CS=canvas_size, NC=num_canvases, TC=NC*CS, FS=P+TC
flowchart TB
    x0(["x0 = batch.canvas<br/>[B, TC, 1]"]):::tensor
    pr(["prompt<br/>[B, P]"]):::tensor
    TS["UniformTimeSampler<br/>t ~ U(eps, 1-eps)"]:::module
    COR["corruption_process.corrupt<br/>keep w.p. alpha=1-t else uniform"]:::module
    xt(["x_t<br/>[B, TC, 1]"]):::tensor
    SEL["sample selected_canvas_idx<br/>~ U[0, num_valid) per example"]:::op
    ENC["sft_encode: causal AR prefill<br/>over prompt ++ x0 (encoder pass)<br/>+ set_cache_end_index"]:::module
    kv[("KV cache<br/>k,v: [B, FS, N_kv, d] x N_L<br/>end_index = P + idx*CS")]:::tensor
    elog(["encoder_logits<br/>[B, FS, V]"]):::tensor
    DEC1["sft_decode pass 1<br/>(denoiser, no self-cond)"]:::module
    SCG["self-cond gate:<br/>stop_grad + Bernoulli(0.5) per example"]:::op
    DEC2["sft_decode pass 2<br/>(denoiser + sc_logits)"]:::module
    dlog(["denoiser logits<br/>[B, TC, V]"]):::tensor
    DL["diffusion_loss<br/>NoWeightDiscreteLoss<br/>CE(logits, x0) on target_mask"]:::loss
    EL["encoder_loss<br/>EncoderARLoss<br/>CE(encoder_logits, next-token)"]:::loss

    x0 -- "[B, TC, 1]" --> TS
    TS -- "t [B, 1, 1]" --> COR
    x0 -- "[B, TC, 1]" --> COR
    COR -- "[B, TC, 1]" --> xt
    pr -- "[B, P]" --> ENC
    x0 -- "x0 tokens [B, TC]" --> ENC
    SEL -- "idx [B]" --> ENC
    ENC -- "cache" --> kv
    ENC -- "[B, FS, V]" --> elog
    xt -- "[B, TC, 1]" --> DEC1
    kv -. "read (frozen at end_index)" .-> DEC1
