%% Data pipeline — visual sudoku (make_sudoku_vision_ds) [DESIGN]
%% Purple solid = new transforms/fields; dashed purple = modified ones.
flowchart TB
    bagz(["Bagz record<br/>{puzzle_image, solution}"]):::modtensor
    PARSE["ParseSudokuVisionExample<br/>decode image; prompt text contains &lt;|image|&gt;"]:::newmod
    TOK["FormatText + Tokenize<br/>&lt;|image|&gt; = single id 258880"]:::modmod
    PREP["PreprocessAndPatchifyImage<br/>resize (mult. of 48px) + normalize + patchify"]:::newmod
    EXP["ExpandImagePlaceholders<br/>&lt;|image|&gt; -> &#92;n&#92;n &lt;soi&gt; [-2] x S_v &lt;eoi&gt; &#92;n&#92;n"]:::newmod
    PAD["Pad prompt to P = 384"]:::modmod
    CHUNK["CanvasChunker (unchanged)<br/>canvas / canvas_id / canvas_mask"]:::module
    SHIFT["SequenceTargetShift<br/>+ zero encoder_target_mask on soft-token slots"]:::modmod
    batch(["batch: prompt [B,P], patches [B,P_p,p_d], positions_xy [B,P_p,2],<br/>canvas [B,TC,1], canvas_id, canvas_mask,<br/>encoder_target [B,FS], encoder_target_mask [B,FS]"]):::modtensor
    bagz -- "image [H, W, 3]" --> PREP
    bagz -- "prompt/solution text" --> PARSE
    PARSE -- "strings" --> TOK
    PREP -- "patches [P_p, p_d], positions_xy [P_p, 2], S_v" --> EXP
    TOK -- "prompt ids (1 placeholder)" --> EXP
    EXP -- "prompt ids [len + S_v + 3]" --> PAD
    TOK -- "response ids" --> CHUNK
    PAD -- "prompt [P]" --> SHIFT
    CHUNK -- "canvas [TC]" --> SHIFT
    SHIFT -- "per-example fields" --> batch
    PREP -- "patches, positions_xy" --> batch
    classDef module fill:#dbeafe,stroke:#2563eb,color:#1e3a5f
    classDef newmod fill:#f3e8ff,stroke:#9333ea,stroke-width:2px,color:#4c1d95
    classDef modmod fill:#dbeafe,stroke:#9333ea,stroke-width:2.5px,stroke-dasharray:6 3,color:#1e3a5f
    classDef modtensor fill:#fef3c7,stroke:#9333ea,stroke-width:2.5px,stroke-dasharray:6 3,color:#7c2d12
